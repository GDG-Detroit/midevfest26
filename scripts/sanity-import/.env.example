# Copy to scripts/sanity-import/.env (gitignored) or inject via n8n credentials.
# import-speakers.mjs: node --env-file=scripts/sanity-import/.env scripts/sanity-import/import-speakers.mjs
# fetch-event-data.mjs: loads this file automatically when present; otherwise uses defaults.

# Sanity (create token at sanity.io/manage → API → Tokens, Editor permission)
SANITY_PROJECT_ID=b18a6pbd
SANITY_DATASET=production
SANITY_API_TOKEN=

# Event anchor — use ONE of:
SANITY_EVENT_YEAR=2026
# SANITY_EVENT_ID=

# Google (service account JSON path — share Sheet + Drive folder with client_email)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/n8n-google-sheets-service-account.json
GOOGLE_SHEET_ID=
GOOGLE_SHEET_RANGE=Sheet1
GOOGLE_DRIVE_FOLDER_ID=

# Optional: Vercel deploy hook (n8n HTTP Request node after successful import)
# VERCEL_DEPLOY_HOOK_URL=
